---
---
<section class="relative overflow-hidden" transition:name="hero">
  <img
    src="https://images.unsplash.com/photo-1517849845537-4d257902454a?auto=format&fit=crop&w=1600&q=80"
    alt="Dog on a walk"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />
  <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(20,45,41,0.92) 0%, rgba(20,45,41,0.75) 45%, rgba(20,45,41,0.35) 70%, rgba(0,0,0,0.2) 100%);"></div>

  <div class="container-blog relative z-10 py-20 md:py-28 min-h-[520px] flex items-center">
    <div class="grid lg:grid-cols-2 gap-12 items-center w-full">
      <div class="max-w-2xl" transition:name="hero-copy">
        <span class="pill-badge mb-4">Premium Desktop Page</span>
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-white">
          Expert Pet Care for a Brighter Future.
        </h1>
        <p class="text-lg md:text-xl mt-6 max-w-2xl" style="color: rgba(242,240,235,0.9);">
          Discover vet-approved advice and reviews for a healthier, happier furry friend.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-8">
          <a href="/blog" class="btn-primary text-base font-bold px-7 py-3">
            Explore Advice
          </a>
          <a href="/tags" class="btn-secondary text-base font-bold px-7 py-3">
            Browse Topics
          </a>
        </div>
      </div>

      <div class="hidden lg:block justify-self-end" transition:name="hero-card">
        <div class="glass-panel rounded-3xl p-6 w-[360px] shadow-2xl border border-white/10">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-xl">🐾</div>
            <div>
              <p class="text-sm text-champagne font-semibold uppercase tracking-wide">Trusted by Pet Parents</p>
              <p class="text-2xl font-heading text-white">50,000+</p>
            </div>
          </div>
          <div class="space-y-3 text-sm" style="color: rgba(242,240,235,0.9);">
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-champagne"></span>
              Vet-reviewed guides and tips
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-champagne"></span>
              Honest reviews with zero bias
            </div>
            <div class="flex items-center gap-2">
              <span class="w-2 h-2 rounded-full bg-champagne"></span>
              Weekly updates for every pet stage
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
