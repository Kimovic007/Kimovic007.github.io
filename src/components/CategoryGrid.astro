---
import type { Topic } from '../data/home';
import '../styles/category-grid.css';

const { items } = Astro.props as { items: (Topic & { count?: number })[] };
---
<section class="section-padding topics-section">
  <div class="container-blog">
    <div class="topics-header">
      <h2 class="topics-title">Explore Pet Care Topics</h2>
      <p class="topics-subtitle">Find expert advice across all areas of pet care</p>
    </div>

    <div class="topics-grid">
      {items.map(topic => (
        <a href={topic.href} class="topic-card">
          <div class="topic-icon">
            <span class="icon-emoji">{topic.icon}</span>
          </div>
          <h3 class="topic-name">{topic.name}</h3>
          <div class="topic-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

