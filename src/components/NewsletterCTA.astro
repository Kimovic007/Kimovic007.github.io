---

<section class="mt-12 p-8 rounded-3xl text-white" style="background: linear-gradient(135deg, rgba(20,45,41,0.95), rgba(27,59,54,0.9));">
  <div class="text-center max-w-xl mx-auto">
    <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-6" style="background-color: rgba(255,255,255,0.12);">
      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
        <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
    </div>
    <h3 class="text-2xl font-bold mb-3">Get Weekly Pet Care Tips</h3>
    <p class="mb-6" style="color: rgba(242,240,235,0.85);">
      Join 15,000+ pet lovers and receive expert advice, product reviews, and exclusive deals straight to your inbox.
    </p>
    <form class="flex flex-col sm:flex-row gap-3">
      <input 
        type="email" 
        placeholder="Enter your email"
        class="flex-grow px-4 py-3 newsletter-input"
        required
      />
      <button 
        type="submit"
        class="btn-primary whitespace-nowrap"
      >
        Subscribe Free
      </button>
    </form>
    <p class="text-xs mt-4" style="color: var(--color-alabaster); opacity: 0.7;">
      No spam, unsubscribe anytime. We respect your privacy.
    </p>
  </div>
</section>
